# Copy to .env and fill in real values. Never commit .env — it holds live secrets.
BETTER_AUTH_SECRET=generate-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000
DATABASE_URL=mongodb+srv://user:pass@cluster/peacock

# Comma-separated browser origins allowed CORS on /api/* (e.g. a deployed Expo web client).
# localhost origins are always allowed in dev; native apps need no CORS.
CORS_ORIGINS=
