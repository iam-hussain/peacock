# Copy to .env and fill in real values. Never commit .env — it holds live secrets.
BETTER_AUTH_SECRET=generate-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000
DATABASE_URL=mongodb+srv://user:pass@cluster/peacock

# Comma-separated browser origins allowed CORS on /api/* (e.g. a deployed Expo web client).
# localhost origins are always allowed in dev; native apps need no CORS.
CORS_ORIGINS=

# Cron endpoints (/api/cron/*) — Vercel sends `Authorization: Bearer $CRON_SECRET`.
# Unset = open (local dev only); ALWAYS set in production.
CRON_SECRET=

# WhatsApp Business Cloud API (api/whatsapp webhook + replies). Unset = bot disabled.
# Token + phone-number id from Meta developer dashboard → WhatsApp → API Setup.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# The verify token YOU invent and paste into the dashboard's webhook config.
WHATSAPP_VERIFY_TOKEN=
# App secret (dashboard → App settings → Basic) — signs webhook payloads.
# Unset = signature check skipped (local dev only); ALWAYS set in production.
WHATSAPP_APP_SECRET=

# Monthly backup email (api/cron/backup). Unset = the cron reports "skipped".
RESEND_API_KEY=
BACKUP_EMAIL_TO=admin@example.com
# Optional; defaults to Resend's onboarding sender (fine until a domain is verified).
BACKUP_EMAIL_FROM=
